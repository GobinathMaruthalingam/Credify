{
    "version": 2,
    "buildCommand": null,
    "outputDirectory": "./",
    "cleanUrls": true,
    "routes": [
        {
            "src": "/",
            "dest": "/coming_soon.html"
        },
        {
            "src": "/verify/(.*)",
            "dest": "https://credify.gnmlabs.com/verify/$1"
        },
        {
            "src": "/dashboard(.*)",
            "dest": "https://credify.gnmlabs.com/dashboard"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}